# Камера: RTSP-ссылка, IP-камера или 0 (USB)
CAMERA_SOURCE=/dev/video0
# Время хранения буфера (часы)
BUFFER_HOURS=48

# Длительность одного чанка (секунды)
CHUNK_DURATION_SEC=300

# Допуск "почти в начале/конце" (минуты)
TOLERANCE_MIN=10

# Модель YOLO: n/s/m/l/x (n - быстрее, x - точнее)
MODEL_SIZE=yolov8n.pt

# Пропуск кадров для снижения нагрузки (1 - каждый кадр, 3 - каждый 3-й)
FRAME_INTERVAL=2